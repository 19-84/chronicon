{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chronicon-archive": {
      "type": "local",
      "command": [
        "/path/to/your/.venv/bin/python",
        "-m",
        "chronicon.cli",
        "mcp"
      ],
      "environment": {
        "DATABASE_URL": "sqlite:////absolute/path/to/your/archive.db"
      },
      "enabled": true
    }
  }
}
