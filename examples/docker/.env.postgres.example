# PostgreSQL Configuration
# IMPORTANT: Change POSTGRES_PASSWORD before using in production!
POSTGRES_PASSWORD=change_me_in_production

# Export Formats
# Options: html, markdown, html,markdown (hybrid)
EXPORT_FORMATS=html

# Git Push Integration (optional)
# Supports GitHub, GitLab, Forgejo, Gitea, etc.
GIT_PUSH_ENABLED=false
GIT_REMOTE_URL=
GIT_USERNAME=
GIT_TOKEN=

# Examples:
# GitHub:
#   GIT_REMOTE_URL=https://github.com/username/archive-repo.git
#   GIT_USERNAME=username
#   GIT_TOKEN=ghp_xxxxxxxxxxxx
#
# GitLab:
#   GIT_REMOTE_URL=https://gitlab.com/username/archive-repo.git
#   GIT_USERNAME=username
#   GIT_TOKEN=glpat-xxxxxxxxxxxx
#
# Forgejo/Gitea:
#   GIT_REMOTE_URL=https://forgejo.example.com/username/archive-repo.git
#   GIT_USERNAME=username
#   GIT_TOKEN=xxxxxxxxxxxx
