# Chronicon Configuration Example
# Copy this file to .chronicon.toml and customize

[general]
output_dir = "./archives"
default_formats = ["html", "markdown", "github"]

[fetching]
rate_limit_seconds = 0.5
max_workers = 8
retry_max = 5
timeout = 15
exponential_backoff_base = 2

[export]
# Common export settings
include_users = false
text_only = false

# Base URL for canonical links (for SEO when hosting online)
# Example: "https://example.github.io/forum-archive" or "https://archive.example.com"
# Leave commented out for offline-only archives
# canonical_base_url = "https://example.github.io/forum-archive"

[export.html]
theme_adaptation = "simplified"  # simplified, full, minimal
enable_search = true
responsive = true

[export.markdown]
convert_html = true
preserve_formatting = true
include_metadata_header = true

[export.github]
generate_readme = true
relative_image_paths = true
gfm_syntax = true

# Continuous mode settings
[continuous]
polling_interval_minutes = 10
max_consecutive_errors = 5
error_backoff_multiplier = 2.0

[continuous.git]
enabled = false
auto_commit = true
commit_on_each_update = true  # false to batch commits
push_to_remote = false
remote_name = "origin"
branch = "main"
commit_message_template = "chore: update archive - {new_posts} new, {modified_posts} modified, {topics} topics"

# Site-specific settings (optional)
[[sites]]
url = "https://meta.discourse.org"
nickname = "meta"
categories = [1, 2, 7]  # only these categories
rate_limit_seconds = 1.0  # slower for public site

[[sites]]
url = "https://discuss.example.com"
nickname = "example"
# archive all categories
